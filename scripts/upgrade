#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

ynh_script_progression --message="Stopping Gitea MCP..." --weight=1
ynh_systemctl --service="$app" --action="stop" --log_path="systemd" || true

ynh_script_progression --message="Updating the immutable image pin..." --weight=1
install -m 0644 "$YNH_APP_BASEDIR/conf/image.env" "$install_dir/image.env"
chown "$app:$app" "$install_dir/image.env"
load_image_pin "$install_dir/image.env"

ynh_script_progression --message="Pulling the validated Gitea MCP image..." --weight=2
ynh_systemctl --service="docker" --action="start" --log_path="systemd"
docker pull "$image"

ynh_script_progression --message="Refreshing reverse proxy and service..." --weight=2
ynh_config_add_nginx
ynh_config_add_systemd
yunohost service add "$app" --description="Official Model Context Protocol server for Gitea"

ynh_script_progression --message="Starting Gitea MCP..." --weight=1
ynh_systemctl --service="$app" --action="start" --log_path="systemd"
ynh_systemctl --service="$app" --action="status" --log_path="systemd"

ynh_script_progression --message="Upgrade of $app completed" --last
